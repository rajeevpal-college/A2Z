#include <iostream>
using namespace std;

int main() {
    int n = 5; // Total number of rows

    // Outer loop controls the rows
    for (int i = 0; i < n; i++) {
        
        // Inner loop prints stars decreasingly
        for (int j = 0; j < n - i; j++) {
            cout << "*";
        }
        
        // Move to the next line
        cout << endl;
    }
    return 0;
}
